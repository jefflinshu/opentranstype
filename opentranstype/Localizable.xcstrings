        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ตรวจสอบแพ็กภาษาสำหรับการแปลบนอุปกรณ์โดยอัตโนมัติ ภาษาต้นทางจะถูกตรวจจับจากข้อความที่คุณป้อนเมื่อทำการแปล"
